# 실제 값은 .env 에 넣고, .env 는 절대 커밋하지 않는다 (.gitignore 등록됨)
# 저장소가 공개이므로 DB 호스트 주소도 여기 적지 않는다.

# --- DB (기존 MySQL 5.7 서버의 tenant_saas 스키마) ---
SAAS_DB_URL=jdbc:mysql://<db-host>:3306/tenant_saas?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Seoul&characterEncoding=UTF-8

# 런타임 계정: DML 만 가능, tenant_saas 외 접근 불가
SAAS_DB_USER=saas_app
SAAS_DB_PASSWORD=

# 마이그레이션 계정: tenant_saas 에 한해 DDL 가능
SAAS_DB_MIGRATE_USER=saas_migrate
SAAS_DB_MIGRATE_PASSWORD=

# --- JWT (32바이트 이상) ---
SAAS_JWT_SECRET=

# --- 플랫폼 관리자 최초 부트스트랩 (1회 실행 후 false 로 되돌릴 것) ---
SAAS_ADMIN_BOOTSTRAP=false
SAAS_ADMIN_EMAIL=
SAAS_ADMIN_PASSWORD=
SAAS_ADMIN_NAME=
